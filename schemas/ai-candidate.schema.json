{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "model",
    "prompt_digest",
    "input_sha256",
    "candidates",
    "review_state"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "model": {
      "type": "object",
      "required": [
        "provider",
        "name",
        "version"
      ],
      "properties": {
        "provider": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "prompt_digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "input_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "field",
          "value",
          "anchors"
        ],
        "properties": {
          "field": {
            "type": "string"
          },
          "value": {},
          "anchors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "confidence": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0,
            "maximum": 1
          },
          "warnings": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "review_state": {
      "const": "candidate"
    }
  }
}
